{
  "name": "aso-video",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,api -c magenta,cyan \"npm:dev:vite\" \"npm:dev:api\"",
    "dev:vite": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "start": "tsx server/index.ts",
    "render": "tsx cli/render.ts",
    "generate-v1": "tsx cli/generate-v1.ts",
    "compare-voices": "tsx cli/generate-voices-compare.ts",
    "compare-captions": "tsx cli/render-captions-compare.ts",
    "remotion:studio": "remotion studio remotion/index.ts"
  },
  "dependencies": {
    "@fal-ai/client": "^1.10.1",
    "@remotion/captions": "^4.0.420",
    "@remotion/cli": "^4.0.420",
    "@remotion/player": "^4.0.420",
    "@remotion/preload": "^4.0.420",
    "@xyflow/react": "^12.10.2",
    "express": "^5.0.1",
    "multer": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remotion": "^4.0.420"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.7.0",
    "vite": "^8.0.0"
  }
}
