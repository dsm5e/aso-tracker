# Apple Search Ads (orgId, OAuth client credentials, ES256 private key)
# https://ads.apple.com — admin → Settings → API
ASA_CLIENT_ID=SEARCHADS.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASA_TEAM_ID=SEARCHADS.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASA_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASA_PRIVATE_KEY_PATH=/absolute/path/to/asa-private.p8
ASA_ORG_ID=00000000

# App Store Connect API (for installs→trials cross-match)
# https://appstoreconnect.apple.com — Users and Access → Integrations → App Store Connect API
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_PRIVATE_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
ASC_VENDOR_NUMBER=00000000

# Server
PORT=5181
DATA_DIR=./data

# Revenue cross-match (optional) — wire your own Cloud Functions to overlay real
# revenue/ROAS on ASA spend. Leave unset to stay on the country-average estimate.
# Apple adamIds of the apps each feed covers (0 / unset = disabled):
GEO_REVENUE_APP_ID=0
KEYWORD_REVENUE_APP_ID=0
# Geo-grained feed → { rows: [{ country, trials, paid, revenueUsd }] }
GEO_REVENUE_FN_URL=
GEO_REVENUE_KEY=
# Per-keyword feed (AdServices attribution), folded to country grain server-side
KEYWORD_REVENUE_FN_URL=
KEYWORD_REVENUE_APP_SLUG=
KEYWORD_REVENUE_KEY=

# Telegram alerts (optional)
ALERTS_ENABLED=false
TG_BOT_TOKEN=
TG_CHAT_ID=
ALERT_INTERVAL_MIN=30
ALERT_CPI_THRESHOLD=2.0
ALERT_SPEND_NO_INSTALL=5.0
