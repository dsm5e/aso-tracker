{
  "name": "aso-studio-monorepo",
  "private": true,
  "version": "0.2.0",
  "workspaces": [
    "aso-keywords",
    "aso-screenshots",
    "aso-video",
    "asa-ads"
  ],
  "scripts": {
    "dev": "concurrently -n keywords,screenshots,video,asa -c magenta,cyan,green,yellow \"npm:dev:keywords\" \"npm:dev:screenshots\" \"npm:dev:video\" \"npm:dev:asa\"",
    "dev:keywords": "npm --workspace aso-keywords run dev",
    "dev:screenshots": "npm --workspace aso-screenshots run dev",
    "dev:video": "npm --workspace aso-video run dev",
    "dev:asa": "npm --workspace asa-ads run dev",
    "open": "open http://localhost:5173 http://localhost:5180 http://localhost:5190 http://localhost:5193"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
